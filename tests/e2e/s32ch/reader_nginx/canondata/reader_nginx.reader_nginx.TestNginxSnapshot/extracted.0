CREATE TABLE nginx.access_log
(
    `__file_name` Nullable(String),
    `__row_index` Nullable(UInt64),
    `remote_addr` Nullable(String),
    `remote_user` Nullable(String),
    `date_time` Nullable(DateTime),
    `request` Nullable(String),
    `status_code` Nullable(Int64),
    `body_bytes_sent` Nullable(Int64),
    `http_referer` Nullable(String),
    `http_user_agent` Nullable(String),
    `bytes_sent` Nullable(Int64),
    `edgename` Nullable(String),
    `scheme` Nullable(String),
    `host` Nullable(String),
    `request_time` Nullable(Float64),
    `upstream_response_time` Nullable(String),
    `request_length` Nullable(Int64),
    `http_range` Nullable(String),
    `responding_node` Nullable(String),
    `upstream_cache_status` Nullable(String),
    `upstream_response_length` Nullable(String),
    `upstream_addr` Nullable(String),
    `gcdn_api_client_id` Nullable(String),
    `gcdn_api_resource_id` Nullable(String),
    `uid_got` Nullable(String),
    `uid_set` Nullable(String),
    `geoip_country_code` Nullable(String),
    `geoip_city` Nullable(String),
    `shield_type` Nullable(String),
    `server_addr` Nullable(String),
    `server_port` Nullable(Int64),
    `upstream_status` Nullable(String),
    `upstream_connect_time` Nullable(String),
    `upstream_header_time` Nullable(String),
    `shard_addr` Nullable(String),
    `geoip2_data_asnumber` Nullable(String),
    `connection` Nullable(Int64),
    `connection_requests` Nullable(Int64),
    `request_id` Nullable(String),
    `http_x_forwarded_proto` Nullable(String),
    `http_x_forwarded_request_id` Nullable(String),
    `ssl_cipher` Nullable(String),
    `ssl_session_id` Nullable(String),
    `ssl_session_reused` Nullable(String),
    `sent_http_content_type` Nullable(String),
    `tcpinfo_rtt` Nullable(String),
    `http_x_forwarded_http_ver` Nullable(String),
    `vp_enabled` Nullable(String),
    `geoip2_region` Nullable(String)
)
ENGINE = MergeTree
ORDER BY (remote_addr, date_time, request, host)
SETTINGS allow_nullable_key = 1, index_granularity = 8192